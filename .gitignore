# Comprehensive .gitignore for Node.js and Vite Projects

# Node.js dependencies
node_modules/

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Build output
/dist/
/build/

# Vite
/.vite/
.vite/

# OS files
.DS_Store
Thumbs.db

# IDE configurations
/.idea/
.vscode/
*.sublime-workspace
*.sublime-project

# Sensitive files
.env
.env.local
.env.*.local
*.key
*.pem
*.crt
*.csr
*.p12
*.pfx

# Miscellaneous
*.tgz
*.gz
*.zip
*.7z
*.rar
